# Keep the build context lean for the gateway Dockerfile (and future BC apps).

# Gradle / Java
**/build/
**/.gradle/
**/target/
*.class

# Node / Next.js (M2+ client)
**/node_modules/
**/.next/
**/out/

# IDE
.idea/
.vscode/
*.iml

# VCS
.git/
.gitignore

# Env / secrets
**/.env
**/.env.local

# Docs + tooling that the gateway build doesn't need
docs/
.claude/
.superpowers/
README.md
