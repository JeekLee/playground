# Environment template — copy to infra/.env and fill in real values before
# `docker compose --env-file .env up`. infra/.env is gitignored.

# --- Postgres (ADR-05) ---
POSTGRES_USER=playground
POSTGRES_PASSWORD=change-me-in-real-env

# --- Kafka KRaft (ADR-03) ---
# Base64-encoded 22-char UUID. Generate per environment:
#   docker run --rm apache/kafka:3.8.0 /opt/kafka/bin/kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# --- Spring profile ---
# Single environment per ADR-07 §"Hosting model" — no dev/prod split. The same
# stack runs on the host server and is reachable both at http://localhost:18080
# (operator loopback) and at https://playground.jeeklee.com (Cloudflare Tunnel).
# Defaults below apply equally to both surfaces.
SPRING_PROFILES_ACTIVE=default

# --- External: spark-inference-gateway (host process, reachable via extra_hosts) ---
# Used by rag-ingestion (M3) for BGE-M3 embeddings and rag-chat (M4) for Qwen3-32B.
# Not consumed by any service in M0/M1, but the gateway already wires the env var
# so M3+ can pick it up without re-bootstrapping compose.
SPARK_INFERENCE_GATEWAY_URL=http://host.docker.internal:10080

# --- M1: Google OAuth2 Client (consumed by the gateway, ADR-07 + ADR-10) ---
# Obtain from Google Cloud Console -> APIs & Services -> Credentials.
# Authorized redirect URIs registered there must include BOTH:
#   https://playground.jeeklee.com/login/oauth2/code/google
#   http://localhost:18080/login/oauth2/code/google
# Authorized JavaScript origins:
#   https://playground.jeeklee.com
#   http://localhost:18080
# Copy the values into infra/.env (gitignored). NEVER commit real credentials.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- M1: Public domain (used by the gateway for the OAuth redirect base URL) ---
# Cloudflare Tunnel terminates HTTPS here and forwards to localhost:18080.
PLAYGROUND_PUBLIC_BASE_URL=https://playground.jeeklee.com

# --- M1: Gateway → identity-api bootstrap + Redis cache (ADR-10 §4) ---
# Defaults match the compose service names; override only if you point at an
# external Redis or move identity-api to a different hostname.
IDENTITY_BASE_URL=http://identity-api:18081
REDIS_HOST=redis-playground
REDIS_PORT=6379
# Set to `false` ONLY when testing on http://localhost without Cloudflare Tunnel.
# Production (Cloudflare Tunnel terminates TLS upstream) must keep this `true`.
PLAYGROUND_COOKIES_SECURE=true

# --- M1: identity-api Postgres connection (defaults match compose service names) ---
POSTGRES_HOST=postgres-playground
POSTGRES_PORT=5432
POSTGRES_DB=playground
KAFKA_BOOTSTRAP_SERVERS=kafka-playground:9092

# --- M1: frontend SSR → gateway (compose-internal) ---
NODE_ENV=production
GATEWAY_INTERNAL_URL=http://gateway:18080

# --- M2 S1: docs-api (ADR-12) ---
# Gateway routes /api/docs/** here. Defaults match the compose service name;
# override only if you point at an external docs-api host.
DOCS_BASE_URL=http://docs-api:18082

# --- M2 S2: docs-api search projection + owner resolution (ADR-12 §5 + §8) ---
# OpenSearch endpoint for the docs-v1 index (created by docs-api at boot).
# Default matches the compose service name; override only if you point at an
# external OpenSearch cluster.
OPENSEARCH_BASE_URL=http://opensearch-playground:9200

# Google sub (subject) of the site owner. When set, /api/docs/owner returns
# this user's id and the public home shows their latest published docs.
# Leave empty for dev/anonymous (public feed returns an empty list per
# ADR-12 §8 fail-closed behavior).
PLAYGROUND_OWNER_GOOGLE_SUB=

# --- M3: rag-ingestion (ADR-13 §A + §B + §10) ---
# rag-ingestion-api binds 18083 actuator-only (no host port, no gateway route).
# Body-fetch target (docs-api `/internal/docs/public/{id}/body`, ADR-08 Exception 1).
# Default matches the compose service name; override only if docs-api moves.
DOCS_API_BASE_URL=http://docs-api:18082

# spark-inference-gateway via the OpenAI-compatible vLLM endpoint (ADR-04 + ADR-13 §10).
# Used by rag-ingestion-api's Spring AI EmbeddingModel bean for BGE-M3 (1024-dim) batches
# of up to 32 chunks per call. Default targets the host-process gateway at port 10080
# (reached through `extra_hosts: host.docker.internal:host-gateway`). The same SPARK_INFERENCE_GATEWAY_URL
# above is unrelated — it's the gateway BC's own pointer; Spring AI binds its own property.
SPRING_AI_OPENAI_BASE_URL=http://host.docker.internal:10080
# vLLM does not validate API keys for self-hosted deployments, but Spring AI's OpenAI
# starter requires the property to be present and non-empty — supply a dummy value.
SPRING_AI_OPENAI_API_KEY=dummy-not-used
