# Environment template — copy to infra/.env and fill in real values before
# `docker compose --env-file .env up`. infra/.env is gitignored.

# --- Postgres (ADR-05) ---
POSTGRES_USER=playground
POSTGRES_PASSWORD=change-me-in-real-env

# --- Kafka KRaft (ADR-03) ---
# Base64-encoded 22-char UUID. Generate per environment:
#   docker run --rm apache/kafka:3.8.0 /opt/kafka/bin/kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# --- Spring profile ---
# Single environment per ADR-07 §"Hosting model" — no dev/prod split. The same
# stack runs on the host server and is reachable both at http://localhost:18080
# (operator loopback) and at https://playground.jeeklee.com (Cloudflare Tunnel).
# Defaults below apply equally to both surfaces.
SPRING_PROFILES_ACTIVE=default

# --- External: spark-inference-gateway endpoint ---
# Used by rag-ingestion (M3) for BGE-M3 embeddings and rag-chat (M4) for the
# active Qwen3 chat model (default `qwen3-vl-30b-a3b` multimodal MoE as of
# M6 swap — replaced the text-only `qwen3-30b-a3b` MoE; both share the same
# 32 k context window so ADR-14 §8 token budget split is unchanged, and the
# VL model is also what docs-api uses for PDF page → markdown OCR per
# ADR-16). Override either via `SPRING_AI_CHAT_MODEL` below or by loading
# a differently-named model in the host gateway.
#
# Two supported wiring shapes (see ADR-04 amendment 2026-05-20):
#  (a) Spark stack as a separate compose project on `spark-inference-net`
#      bridge — the playground services are pre-attached to this network in
#      `infra/docker-compose.yml`, so use the gateway container name. The
#      gateway container LISTENS ON 8000 internally (the host's `10080:8000`
#      port mapping is what surfaces it on `127.0.0.1:10080` for browser
#      probes); from inside the bridge it's always `:8000`:
#        SPARK_INFERENCE_GATEWAY_URL=http://spark-inference-gateway:8000
#  (b) Bare vLLM on the host at 127.0.0.1:10080 (original ADR-04 wiring,
#      requires the host process to bind 0.0.0.0):
#        SPARK_INFERENCE_GATEWAY_URL=http://host.docker.internal:10080
#
# The example below uses shape (a). Pick the shape that matches your stack
# and keep `SPRING_AI_OPENAI_BASE_URL` lower in this file consistent.
SPARK_INFERENCE_GATEWAY_URL=http://spark-inference-gateway:8000

# --- M4: Spring AI chat model name (host spark-inference-gateway must expose it) ---
# Sent as the OpenAI-compatible `model` field on every /v1/chat/completions
# call from rag-chat-api. The default lives in
# `backend/rag-chat/rag-chat-api/src/main/resources/application.yml`; this
# env override is the no-rebuild knob for swapping models on the fly.
SPRING_AI_CHAT_MODEL=qwen3-vl-30b-a3b

# --- M6 (ADR-16): docs-api PDF support — Vision OCR model ---
# Multimodal model name sent on the OpenAI-compatible /v1/chat/completions
# call from docs-api when a PDF page has no extractable text layer (scanned
# image-only pages). The default lives in
# `backend/docs/docs-api/src/main/resources/application.yml`; this env
# override is the no-rebuild knob for swapping models on the fly while the
# host spark-inference-gateway is still warming the weights.
#
# When the model is unavailable, the Vision OCR adapter returns an empty
# string for the failing page rather than failing the whole upload — the
# remaining text-layer pages still land in the body.
SPRING_AI_VISION_MODEL=qwen3-vl-30b-a3b

# --- M1: Google OAuth2 Client (consumed by the gateway, ADR-07 + ADR-10) ---
# Obtain from Google Cloud Console -> APIs & Services -> Credentials.
# Authorized redirect URIs registered there must include BOTH:
#   https://playground.jeeklee.com/login/oauth2/code/google
#   http://localhost:18080/login/oauth2/code/google
# Authorized JavaScript origins:
#   https://playground.jeeklee.com
#   http://localhost:18080
# Copy the values into infra/.env (gitignored). NEVER commit real credentials.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- M1: Public domain (used by the gateway for the OAuth redirect base URL) ---
# Cloudflare Tunnel terminates HTTPS here and forwards to localhost:18080.
PLAYGROUND_PUBLIC_BASE_URL=https://playground.jeeklee.com

# --- M1: Gateway → identity-api bootstrap + Redis cache (ADR-10 §4) ---
# Defaults match the compose service names; override only if you point at an
# external Redis or move identity-api to a different hostname.
IDENTITY_BASE_URL=http://identity-api:18081
REDIS_HOST=redis-playground
REDIS_PORT=6379
# Set to `false` ONLY when testing on http://localhost without Cloudflare Tunnel.
# Production (Cloudflare Tunnel terminates TLS upstream) must keep this `true`.
PLAYGROUND_COOKIES_SECURE=true

# --- M1: identity-api Postgres connection (defaults match compose service names) ---
POSTGRES_HOST=postgres-playground
POSTGRES_PORT=5432
POSTGRES_DB=playground
KAFKA_BOOTSTRAP_SERVERS=kafka-playground:9092

# --- M1: frontend SSR → gateway (compose-internal) ---
NODE_ENV=production
GATEWAY_INTERNAL_URL=http://gateway:18080

# --- M2 S1: docs-api (ADR-12) ---
# Gateway routes /api/docs/** here. Defaults match the compose service name;
# override only if you point at an external docs-api host.
DOCS_BASE_URL=http://docs-api:18082

# --- M2 S2: docs-api search projection + owner resolution (ADR-12 §5 + §8) ---
# OpenSearch endpoint for the docs-v1 index (created by docs-api at boot).
# Default matches the compose service name; override only if you point at an
# external OpenSearch cluster.
OPENSEARCH_BASE_URL=http://opensearch-playground:9200

# Google sub (subject) of the site owner. When set, /api/docs/owner returns
# this user's id and the public home shows their latest published docs.
# Leave empty for dev/anonymous (public feed returns an empty list per
# ADR-12 §8 fail-closed behavior).
PLAYGROUND_OWNER_GOOGLE_SUB=

# --- M3: rag-ingestion (ADR-13 §A + §B + §10) ---
# rag-ingestion-api binds 18083 actuator-only (no host port, no gateway route).
# Body-fetch target (docs-api `/internal/docs/public/{id}/body`, ADR-08 Exception 1).
# Default matches the compose service name; override only if docs-api moves.
DOCS_API_BASE_URL=http://docs-api:18082

# spark-inference-gateway via the OpenAI-compatible vLLM endpoint (ADR-04 + ADR-13 §10
# + ADR-14 §B + ADR-04 amendment 2026-05-20). Used by rag-ingestion-api's Spring AI
# EmbeddingModel bean for BGE-M3 (1024-dim) batches AND by rag-chat-api's Spring AI
# ChatClient (Qwen3 streaming) + EmbeddingModel (BGE-M3 query embedding). Pick ONE
# shape — keep it consistent with `SPARK_INFERENCE_GATEWAY_URL` higher up:
#   (a) external compose-net attach (preferred — playground services join the
#       `spark-inference-net` bridge in `infra/docker-compose.yml`). Gateway
#       listens on 8000 inside the bridge (host's `127.0.0.1:10080` is the
#       outside-the-bridge mapping of that same 8000 port):
#         SPRING_AI_OPENAI_BASE_URL=http://spark-inference-gateway:8000
#   (b) host-process fallback (original ADR-04, requires host vLLM on 0.0.0.0):
#         SPRING_AI_OPENAI_BASE_URL=http://host.docker.internal:10080
SPRING_AI_OPENAI_BASE_URL=http://spark-inference-gateway:8000
# Bearer token enforced by the gateway (shape (a)) — copy from the spark-stack's
# own .env. Bare host vLLM (shape (b)) ignores the value; supply any non-empty
# string because Spring AI's OpenAI starter requires the property to be set.
SPRING_AI_OPENAI_API_KEY=dummy-not-used

# --- M4: rag-chat-api (ADR-14 §A + §7) ---
# rag-chat-api binds 18084 (compose-internal only — no host port; gateway routes
# /api/rag/chat/** here per ADR-07 + ADR-14 §2). Reuses the SPRING_AI_OPENAI_*
# variables above (shared spark-inference-gateway endpoint per ADR-04). No new
# Postgres / Redis / Kafka credentials — rag-chat-api shares the same datasource,
# Redis instance, and (no) Kafka surface as the rest of the stack.
#
# Per-turn retrieval K (ADR-14 §7). Default 6; override only for retrieval-recall
# experiments without recompile. The application's `playground.rag-chat.retrieval.k`
# property in application.yml binds this env var. Hourly + daily token buckets
# (60/hr + 200/day per user) and the per-user concurrent-stream cap are
# configuration-only (no env wiring) per ADR-14 §5 + §D — they live in the
# rag-chat-api JAR's application.yml.
PLAYGROUND_RAG_CHAT_RETRIEVAL_K=6

# --- M5 s1: spark probe wiring (ADR-15 §12 amendment 2026-05-20) ---
# `metrics-api`'s health-grid spark cell probes the same gateway rag-chat /
# rag-ingestion call. Two env vars take effect:
#
# * METRICS_SPARK_GATEWAY_BASE_URL — explicit override; falls back to
#   ${SPARK_INFERENCE_GATEWAY_URL} (the unified shared variable defined near
#   the top of this file) when blank. Keep it blank in normal setups so all
#   three BCs share one URL.
# * METRICS_SPARK_GATEWAY_API_KEY — Bearer token for the gateway's
#   `/v1/models` HEAD probe. Falls back to ${SPRING_AI_OPENAI_API_KEY} when
#   blank. Keep blank in normal setups so the key is configured once.
#
# Both are optional. Uncomment only when the metrics probe needs a different
# endpoint or credential from the rag-chat / rag-ingestion shared one.
# METRICS_SPARK_GATEWAY_BASE_URL=http://spark-inference-gateway:8000
# METRICS_SPARK_GATEWAY_API_KEY=sk-spark-metrics-only-token

# --- M5 s1: observability stack (ADR-15 §3 / §4 / §5 / §18) ---
# Prometheus TSDB retention window in days. Consumed by prometheus-playground's
# CLI flag `--storage.tsdb.retention.time=${METRICS_PROM_RETENTION_DAYS}d`.
# 7 days is the personal-scale default (covers the dashboard's 7d range preset).
METRICS_PROM_RETENTION_DAYS=7

# Loki retention window in days. Consumed by loki-playground (templated into the
# loki config's `limits_config.retention_period` at compose start per ADR-15 §18).
# 3 days is the personal-scale default; tune up only if longer log forensics are
# needed.
METRICS_LOKI_RETENTION_DAYS=3

# Dashboard auto-refresh cadence in seconds. Echoed by metrics-api in the
# dashboard payload as `pollIntervalSeconds` (consumed by the frontend so the
# refresh interval is not hardcoded in JS).
METRICS_POLL_INTERVAL_S=15

# Per-IP rate limit on GET /api/metrics/dashboard (token-bucket, refills every
# minute). Per ADR-15 §C + spec §8.2 (Story 19). Anonymous visitors and the
# operator alike are capped here; /api/metrics/services and
# /api/metrics/timeseries are NOT rate-limited (cheap, separately cacheable).
METRICS_DASHBOARD_RATE_LIMIT_PER_MIN=30

# Per-user rate limit on GET /api/metrics/logs (M5.1 — currently no-op; the
# logs UI lands in a follow-up). Per ADR-15 §C + spec §8.2 (Story 21).
METRICS_LOGS_RATE_LIMIT_PER_MIN=60

# Per-PromQL-query budget in seconds. Above this the widget's cell turns
# `"degraded": true` and the rest of the dashboard composes normally (200 OK
# with partial data). Per ADR-15 §2 + §16 + spec §8.2 (Story 20). NOT a P95
# SLA — the dashboard P95 target is 400 ms; this budget is a fail-safe.
METRICS_PROMQL_BUDGET_S=10

# Backend BC + cAdvisor scrape cadence in seconds. Currently hard-coded into
# `infra/observability/alloy/config.alloy` (5s for BCs + cAdvisor; host stays
# at 10s per ADR-15 §18). This env var is reserved for a future templated-render
# pipeline; today it is documentation-only.
METRICS_SCRAPE_INTERVAL_S=5

# Optional operator-only host port bind for Prometheus :9090 (per ADR-15 §3 /
# spec §4.4 — "ad-hoc PromQL CLI access"). UNSET by default → Prometheus is
# compose-internal only and not reachable from the host. To enable, set to a
# port spec compose will accept, e.g.:
#   PROMETHEUS_HOST_BIND=9090            # publishes 0.0.0.0:9090
#   PROMETHEUS_HOST_BIND=127.0.0.1:9090  # publishes loopback only (recommended)
PROMETHEUS_HOST_BIND=
