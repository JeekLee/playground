# M0 environment template.
# Copy to infra/.env and edit the values before `docker compose --env-file .env up`.

# --- Postgres (ADR-05) ---
POSTGRES_USER=playground
POSTGRES_PASSWORD=change-me-in-real-env

# --- Kafka KRaft (ADR-03) ---
# Base64-encoded 22-char UUID. Generate per environment:
#   docker run --rm apache/kafka:3.8.0 /opt/kafka/bin/kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# --- Spring profile (gateway + future BCs) ---
SPRING_PROFILES_ACTIVE=dev

# --- External: spark-inference-gateway (host process, reachable via extra_hosts) ---
# Used by rag-ingestion (M3) for BGE-M3 embeddings and rag-chat (M4) for Qwen3-32B.
# Not consumed by any service in M0, but the gateway already wires the env var
# so M1+ can pick it up without re-bootstrapping compose.
SPARK_INFERENCE_GATEWAY_URL=http://host.docker.internal:10080

# --- M1: Google OAuth2 Client (populated when ADR-10 / M1 ships) ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
